# Grounded site — environment variables
#
# Local development: copy this file to `.env.local` and fill in what you need.
# Without DATABASE_URL the waitlist API logs to stdout and returns ok:true.

# Cloud SQL via Cloud Run sidecar socket (production):
# DATABASE_URL=postgresql://grounded_app:<pw>@/grounded?host=/cloudsql/<project>:<region>:<instance>

# Cloud SQL via public IP (dev machine):
# DATABASE_URL=postgresql://grounded_app:<pw>@<ip>:5432/grounded?sslmode=require

# Local Postgres (docker):
# DATABASE_URL=postgresql://grounded:grounded@localhost:5432/grounded

# Email (later)
# RESEND_API_KEY=re_xxx
# EMAIL_FROM="Grounded <hello@grounded.dev>"
